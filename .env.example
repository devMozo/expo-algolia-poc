# Optional: set to "true" or "1" to enable Sentry Expo plugin (source maps, etc.)
# SHOULD_ADD_SENTRY_SUPPORT=
# EXPO_PUBLIC_SHOULD_ADD_SENTRY_SUPPORT=

# Sentry (when SHOULD_ADD_SENTRY_SUPPORT is true)
# EXPO_PUBLIC_SENTRY_ORG=
# EXPO_PUBLIC_SENTRY_PROJECT=
# EXPO_PUBLIC_SENTRY_URL=https://sentry.io/
# SENTRY_AUTH_TOKEN=  # For EAS Build source map uploads; do not put in app config

# Google Sign-In – iOS URL scheme from Google Cloud Console (e.g. com.googleusercontent.apps.XXXXX)
# EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=
# GOOGLE_IOS_URL_SCHEME=

# Facebook SDK (optional – plugin is only added when both app ID and client token are set)
# EXPO_PUBLIC_FB_APP_ID=
# EXPO_PUBLIC_FB_CLIENT_TOKEN=
# EXPO_PUBLIC_FB_DISPLAY_NAME=

# Existing (e.g. Algolia)
# ALGOLIA_APP_ID=
# ALGOLIA_API_KEY=
